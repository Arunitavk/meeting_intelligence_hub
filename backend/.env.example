# Anthropic Claude API Key
# Get from: https://console.anthropic.com
# Free tier includes $5 monthly credit
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Google Gemini API Key
# Get from: https://ai.google.dev
# Free tier available with quota limits
GEMINI_API_KEY=your-gemini-api-key-here

# Database URL
# For SQLite (default, no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./meeting_hub.db

# For PostgreSQL (optional):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meeting_hub_db

# Environment: development or production
ENVIRONMENT=development

# CORS Settings
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]

# API Server
API_HOST=127.0.0.1
API_PORT=8000

# Logging
LOG_LEVEL=INFO
